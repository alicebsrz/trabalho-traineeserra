generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Book {
  id        String        @id @default(uuid())
  titulo    String
  autor     String
  sinopse   String        @db.Text
  paginas   Int
  genero    String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("livros")
}